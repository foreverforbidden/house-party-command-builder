<Window x:Class="HpCommander.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HP Commander - House Party V2 Console Command Builder"
        Icon="HP-Commander.ico"
        Width="1150" Height="780" MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Background="{StaticResource ContentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <!-- Sidebar nav: search box over grouped category list -->
        <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBox x:Name="SearchBox" Grid.Row="0" Margin="10,12,10,2"
                     Style="{StaticResource SidebarSearchBoxStyle}"
                     TextChanged="SearchBox_TextChanged"
                     PreviewKeyDown="SearchBox_PreviewKeyDown" />
            <ListBox x:Name="CategoryList" Grid.Row="1"
                     Style="{StaticResource SidebarListBoxStyle}"
                     ItemContainerStyle="{StaticResource SidebarNavItemStyle}"
                     SelectionChanged="CategoryList_SelectionChanged" />
        </Grid>

        <!-- Content area: chip picker row + dynamic content host -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="16,16,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TargetsCard" Grid.Row="0" Style="{StaticResource CardStyle}">
                <ContentControl x:Name="ChipPickerHost" />
            </Border>

            <ScrollViewer x:Name="ContentScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ContentControl x:Name="ContentHost" />
            </ScrollViewer>
        </Grid>

        <!-- Output bar -->
        <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="Command output" Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Grid.Column="1" Grid.Row="0" Text="History (double-click to recopy)" Style="{StaticResource SectionHeaderStyle}" Margin="12,0,0,10" />

                <Grid Grid.Column="0" Grid.Row="1" Margin="0,0,8,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="OutputBox" Grid.Row="0" IsReadOnly="True" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="13" VerticalContentAlignment="Top" Height="Auto"
                             VerticalScrollBarVisibility="Auto" AcceptsReturn="True" Margin="0,0,0,8" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CopyButton" Grid.Column="0" Content="Copy to Clipboard" Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch" Click="CopyButton_Click" />
                        <!-- Sits next to the button it modifies rather than reading as a stray global setting. -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,10" VerticalAlignment="Center">
                            <CheckBox x:Name="AutoCopyCheck" Content="Auto-copy" VerticalAlignment="Center"
                                      ToolTip="Copy the command automatically once it stops changing"
                                      Checked="AutoCopyCheck_Changed" Unchecked="AutoCopyCheck_Changed" />
                            <TextBlock x:Name="CopyStatus" Text="Copied" Margin="10,0,0,0" Opacity="0"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <ListBox x:Name="HistoryList" Grid.Column="1" Grid.Row="1" Margin="12,0,0,0"
                         MouseDoubleClick="HistoryList_MouseDoubleClick" />
            </Grid>
        </Border>
    </Grid>
</Window>
