<UserControl x:Class="HpCommander.Controls.CharacterChipPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Targets" Style="{StaticResource SectionHeaderStyle}" />
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilterBox" Grid.Column="0" Margin="0,0,8,0"
                     TextChanged="FilterBox_TextChanged" />
            <ToggleButton x:Name="AllCharactersChip" Grid.Column="1" Content="All Characters"
                          Style="{StaticResource AllCharactersChipStyle}"
                          Checked="AllCharactersChip_Checked" Unchecked="AllCharactersChip_Unchecked" />
        </Grid>
        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ChipsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Content="{Binding Name}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      IsEnabled="{Binding IsEnabled}"
                                      Style="{StaticResource ChipToggleButtonStyle}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
