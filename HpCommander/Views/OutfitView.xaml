<UserControl x:Class="HpCommander.Views.OutfitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Outfit" Style="{StaticResource SectionHeaderStyle}" />

            <TextBlock Text="Outfit ID (list follows the selected character)" Style="{StaticResource FieldLabelStyle}" />
            <ComboBox x:Name="OutfitCombo" IsEditable="True" Width="320" HorizontalAlignment="Left" />

            <TextBlock Style="{StaticResource NoteTextStyle}" MaxWidth="360"
                       Text="Note: outfit has no false/undo form - to remove pieces afterward use the Change tab per-item." />
        </StackPanel>
    </Border>
</UserControl>
