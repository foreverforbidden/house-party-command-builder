<UserControl x:Class="HpCommander.Views.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Info" Style="{StaticResource SectionHeaderStyle}" />
            <TextBlock Grid.Row="1" Style="{StaticResource NoteTextStyle}" MaxWidth="560"
                       Text="This message is shown to whoever opens the app. Edit it freely and press Save - it's stored in Data/info.txt, which ships next to the build." />

            <TextBox x:Name="InfoBox" Grid.Row="2" Margin="0,4,0,10"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" MinHeight="220"
                     FontFamily="Segoe UI" FontSize="13" Padding="8" />

            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button x:Name="SaveButton" Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveButton_Click" />
                <Button x:Name="ReloadButton" Content="Reload" Click="ReloadButton_Click" />
                <Button x:Name="IssueButton" Content="Report an issue" Click="IssueButton_Click" />
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
