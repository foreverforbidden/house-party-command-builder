<hp:CommandCategoryViewBase x:Class="HpCommander.Views.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hp="clr-namespace:HpCommander.Views">
    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Info" Style="{StaticResource SectionHeaderStyle}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,10">
                <TextBlock x:Name="InfoText" TextWrapping="Wrap" FontSize="13.5"
                           Foreground="{StaticResource TextPrimaryBrush}" LineHeight="20" />
            </ScrollViewer>

            <Button x:Name="IssueButton" Grid.Row="2" Content="Report an issue"
                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"
                    Click="IssueButton_Click" />
        </Grid>
    </Border>
</hp:CommandCategoryViewBase>
