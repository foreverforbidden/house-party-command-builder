<UserControl x:Class="HpCommander.Views.DoorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Door" Style="{StaticResource SectionHeaderStyle}" />

            <TextBlock Text="Door" Style="{StaticResource FieldLabelStyle}" />
            <ComboBox x:Name="DoorCombo" IsEditable="True" Width="300" HorizontalAlignment="Left" />

            <TextBlock Text="Action" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
            <ComboBox x:Name="ActionCombo" Width="300" HorizontalAlignment="Left"
                      SelectionChanged="Selector_Changed" />

            <TextBlock Style="{StaticResource NoteTextStyle}" MaxWidth="440" Margin="0,8,0,0"
                       Text="Doors use the V2 values syntax, e.g. values.frontdoor.set(IsLocked)=1. Lock/unlock set IsLocked; open/close set IsOpen. Picking a door uses its normalised name; a free-typed name is normalised the same way." />
        </StackPanel>
    </Border>
</UserControl>
