<hp:CommandCategoryViewBase x:Class="HpCommander.Views.LegacyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hp="clr-namespace:HpCommander.Views"
             xmlns:controls="clr-namespace:HpCommander.Controls">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Legacy (V1)" Style="{StaticResource SectionHeaderStyle}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Enable" Style="{StaticResource SectionHeaderStyle}" FontSize="13" />

                    <TextBlock Text="Item name to enable" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="EnableItemBox" />
                    <Button x:Name="EnableItemButton" Content="Build 'Item ... setenabled true'"
                            HorizontalAlignment="Left" Click="EnableItemButton_Click" />

                    <TextBlock Text="Spawn/enable or disable a character (e.g. DLC characters not yet in your scene)"
                               Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" TextWrapping="Wrap" MaxWidth="260" />
                    <StackPanel Orientation="Horizontal">
                        <!-- Initial state is set in the constructor, not here: setting IsChecked in XAML
                             fires Checked during InitializeComponent, before EnableNpcButton exists. -->
                        <RadioButton x:Name="NpcEnableRadio" Content="Enable" GroupName="NpcToggle"
                                     Checked="NpcToggle_Changed" />
                        <RadioButton x:Name="NpcDisableRadio" Content="Disable" GroupName="NpcToggle"
                                     Checked="NpcToggle_Changed" />
                    </StackPanel>
                    <controls:FilteringComboBox x:Name="EnableNpcCombo" IsEditable="True" Style="{StaticResource CharacterComboBoxStyle}" />
                    <Button x:Name="EnableNpcButton" Content="Build 'EnableNPC &lt;character&gt;'"
                            HorizontalAlignment="Left" Click="EnableNpcButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Combat" Style="{StaticResource SectionHeaderStyle}" FontSize="13" />

                    <TextBlock Text="Subcommand" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="CombatSubcommandCombo" Style="{StaticResource CharacterComboBoxStyle}"
                              SelectionChanged="CombatSubcommandCombo_SelectionChanged" />

                    <TextBlock Text="Character (or 'all')" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                    <controls:FilteringComboBox x:Name="CombatCharacterCombo" IsEditable="True" Style="{StaticResource CharacterComboBoxStyle}" />

                    <TextBlock x:Name="CombatFightTargetLabel" Text="Fight target" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                    <controls:FilteringComboBox x:Name="CombatFightTargetCombo" IsEditable="True" Style="{StaticResource CharacterComboBoxStyle}" />

                    <TextBlock Style="{StaticResource NoteTextStyle}" MaxWidth="260"
                               Text="Fight only works between enabled characters." />

                    <Button x:Name="CombatButton" Content="Build combat command"
                            HorizontalAlignment="Left" Click="CombatButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Intimacy reference" Style="{StaticResource SectionHeaderStyle}" FontSize="13" />
                    <Button x:Name="IntimacyHelpButton" Content="help intimacy (requires Explicit Content DLC)"
                            HorizontalAlignment="Left" Click="IntimacyHelpButton_Click" />
                    <Button x:Name="IntimacyExampleButton" Content="example intimacy"
                            HorizontalAlignment="Left" Click="IntimacyExampleButton_Click" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</hp:CommandCategoryViewBase>
