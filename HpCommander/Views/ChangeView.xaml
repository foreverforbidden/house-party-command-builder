<hp:TargetedCommandCategoryViewBase x:Class="HpCommander.Views.ChangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hp="clr-namespace:HpCommander.Views"
             xmlns:controls="clr-namespace:HpCommander.Controls">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Change" Style="{StaticResource SectionHeaderStyle}" />

            <TextBlock Text="Clothing slot or item ID (per-character items follow the target selection)"
                       Style="{StaticResource FieldLabelStyle}" />
            <controls:FilteringComboBox x:Name="PartCombo" IsEditable="True" Width="420" HorizontalAlignment="Left" />

            <CheckBox x:Name="ShowAllClothingCheck" Content="Show all clothing (ignore who it's filed under)"
                      Margin="0,2,0,0" Checked="ShowAll_Changed" Unchecked="ShowAll_Changed" />
            <TextBlock x:Name="ClothingSourceNote" Style="{StaticResource NoteTextStyle}" MaxWidth="420" />

            <TextBlock Text="Force state" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ToggleRadio" Content="Toggle (no suffix)" GroupName="ChangeBool"
                             IsChecked="True" Checked="OnToggleChanged" />
                <RadioButton x:Name="TrueRadio" Content="Force On" GroupName="ChangeBool" Checked="OnToggleChanged" />
                <RadioButton x:Name="FalseRadio" Content="Force Off" GroupName="ChangeBool" Checked="OnToggleChanged" />
            </StackPanel>

            <Button x:Name="ListButton" Content="Build change.list command instead"
                    HorizontalAlignment="Left" Click="ListButton_Click" />
        </StackPanel>
    </Border>
</hp:TargetedCommandCategoryViewBase>
