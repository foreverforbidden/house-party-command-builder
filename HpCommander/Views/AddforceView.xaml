<hp:TargetedCommandCategoryViewBase x:Class="HpCommander.Views.AddforceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hp="clr-namespace:HpCommander.Views"
             xmlns:controls="clr-namespace:HpCommander.Controls">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Addforce" Style="{StaticResource SectionHeaderStyle}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Right(+) / Left(-)" Style="{StaticResource FieldLabelStyle}" />
                    <controls:NumericStepper x:Name="RightStepper" Minimum="-200" Maximum="200" Increment="1"
                                              Value="0" ValueChanged="OnValueChanged" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Up(+) / Down(-)" Style="{StaticResource FieldLabelStyle}" />
                    <controls:NumericStepper x:Name="UpStepper" Minimum="-200" Maximum="200" Increment="1"
                                              Value="0" ValueChanged="OnValueChanged" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Forward(+) / Backward(-)" Style="{StaticResource FieldLabelStyle}" />
                    <controls:NumericStepper x:Name="ForwardStepper" Minimum="-200" Maximum="200" Increment="1"
                                              Value="10" ValueChanged="OnValueChanged" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</hp:TargetedCommandCategoryViewBase>
