<UserControl x:Class="HpCommander.Views.MovementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HpCommander.Controls">
    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Movement" Style="{StaticResource SectionHeaderStyle}" />
            <TabControl x:Name="ModeTabs" Style="{StaticResource SegmentedTabControlStyle}"
                        SelectionChanged="ModeTabs_SelectionChanged">

                <TabItem Header="Warp" Style="{StaticResource SegmentedTabItemStyle}">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Character (or 'all')" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="WarpCharCombo" Style="{StaticResource CharacterComboBoxStyle}" SelectionChanged="Selector_Changed" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                            <RadioButton x:Name="WarpDestRadio" Content="To character / location" GroupName="WarpMode"
                                         Checked="WarpMode_Changed" />
                            <RadioButton x:Name="WarpCoordRadio" Content="To coordinates" GroupName="WarpMode" Checked="WarpMode_Changed" />
                        </StackPanel>
                        <ComboBox x:Name="WarpDestCombo" IsEditable="True" Width="260" HorizontalAlignment="Left" />
                        <StackPanel x:Name="WarpCoordPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="X (right/left)" Style="{StaticResource FieldLabelStyle}" />
                                <controls:NumericStepper x:Name="WarpX" Minimum="-500" Maximum="500" Increment="1" Value="0" ValueChanged="Field_Changed" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Y (up/down)" Style="{StaticResource FieldLabelStyle}" />
                                <controls:NumericStepper x:Name="WarpY" Minimum="-500" Maximum="500" Increment="1" Value="0" ValueChanged="Field_Changed" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Z (fwd/back)" Style="{StaticResource FieldLabelStyle}" />
                                <controls:NumericStepper x:Name="WarpZ" Minimum="-500" Maximum="500" Increment="1" Value="0" ValueChanged="Field_Changed" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Style="{StaticResource NoteTextStyle}" MaxWidth="380"
                                   Text="Warp a character to another character (e.g. someone to the Player), a named location, or x/y/z coordinates. Coordinates 0 0 0 attempt to fix a stuck character." />
                    </StackPanel>
                </TabItem>

                <TabItem Header="Walk" Style="{StaticResource SegmentedTabItemStyle}">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Character (or 'all')" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="WalkCharCombo" Style="{StaticResource CharacterComboBoxStyle}" SelectionChanged="Selector_Changed" />
                        <TextBlock Text="Destination" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                        <ComboBox x:Name="WalkDestCombo" IsEditable="True" Width="260" HorizontalAlignment="Left" />
                        <CheckBox x:Name="WalkCancelCheck" Content="Cancel movement instead" Margin="0,10,0,0" Checked="Field_ChangedRouted" Unchecked="Field_ChangedRouted" />
                    </StackPanel>
                </TabItem>

                <TabItem Header="Over Time" Style="{StaticResource SegmentedTabItemStyle}">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Character" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="OverCharCombo" Style="{StaticResource CharacterComboBoxStyle}" SelectionChanged="Selector_Changed" />
                        <TextBlock Text="Destination" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                        <ComboBox x:Name="OverDestCombo" IsEditable="True" Width="260" HorizontalAlignment="Left" />
                        <TextBlock Text="Seconds" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                        <controls:NumericStepper x:Name="OverSeconds" Minimum="0.1" Maximum="60" Increment="0.5" DecimalPlaces="1" Value="3" ValueChanged="Field_Changed" />
                    </StackPanel>
                </TabItem>

                <TabItem Header="Turn" Style="{StaticResource SegmentedTabItemStyle}">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Character" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="TurnCharCombo" Style="{StaticResource CharacterComboBoxStyle}" SelectionChanged="Selector_Changed" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                            <RadioButton x:Name="TurnAroundRadio" Content="Around" GroupName="TurnMode" Checked="TurnMode_Changed" />
                            <RadioButton x:Name="TurnTowardRadio" Content="Toward" GroupName="TurnMode" Checked="TurnMode_Changed" />
                        </StackPanel>
                        <StackPanel x:Name="TurnTowardPanel" Visibility="Collapsed">
                            <TextBlock Text="Toward (character or item)" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="TurnTargetCombo" IsEditable="True" Width="260" HorizontalAlignment="Left" />
                            <CheckBox x:Name="TurnInstantCheck" Content="Turn instantly" Margin="0,10,0,0" Checked="Field_ChangedRouted" Unchecked="Field_ChangedRouted" />
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Roaming" Style="{StaticResource SegmentedTabItemStyle}">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Character (or 'all')" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="RoamCharCombo" Style="{StaticResource CharacterComboBoxStyle}" SelectionChanged="Selector_Changed" />
                        <TextBlock Text="Action" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                        <ComboBox x:Name="RoamActionCombo" Style="{StaticResource CharacterComboBoxStyle}" SelectionChanged="RoamAction_Changed" />
                        <StackPanel x:Name="RoamAllowPanel" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                            <RadioButton x:Name="RoamAllowTrue" Content="Allow" GroupName="RoamAllow" IsChecked="True" Checked="Field_ChangedRouted" />
                            <RadioButton x:Name="RoamAllowFalse" Content="Disallow" GroupName="RoamAllow" Checked="Field_ChangedRouted" />
                        </StackPanel>
                        <StackPanel x:Name="RoamLocationPanel" Margin="0,10,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="RoamLocationLabel" Text="Location / character" Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox x:Name="RoamDestCombo" IsEditable="True" Width="260" HorizontalAlignment="Left" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource NoteTextStyle}" MaxWidth="380" Margin="0,10,0,0"
                                   Text="'list' shows a character's allowed/prohibited roam locations. 'clearlists' resets them, letting them roam anywhere (if roaming is enabled)." />
                    </StackPanel>
                </TabItem>
            </TabControl>
        </StackPanel>
    </Border>
</UserControl>
