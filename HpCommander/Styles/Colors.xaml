<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#20232B" />
    <SolidColorBrush x:Key="SidebarForegroundBrush" Color="#E4E6EB" />
    <SolidColorBrush x:Key="SidebarSelectedBackgroundBrush" Color="#2A2E38" />
    <SolidColorBrush x:Key="SidebarHoverBackgroundBrush" Color="#262A33" />

    <!-- Content -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F5F6F8" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E1E4E8" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#5B8DEF" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#4A7CDB" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#3E68B8" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2430" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="WarningBrush" Color="#C0392B" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#EEF1F6" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#E2E6ED" />

    <!-- Chips -->
    <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#EEF1F6" />
    <SolidColorBrush x:Key="ChipBorderBrush" Color="#D8DCE3" />
    <SolidColorBrush x:Key="ChipTextBrush" Color="#1F2430" />
    <SolidColorBrush x:Key="AllCharactersBorderBrush" Color="#E0A030" />

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D8DCE3" />

</ResourceDictionary>
