<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Same key set as Light.xaml, by contract. -->

    <!-- Sidebar: kept a shade darker than the content so it still reads as a separate rail. -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#15171D" />
    <SolidColorBrush x:Key="SidebarForegroundBrush" Color="#E4E6EB" />
    <SolidColorBrush x:Key="SidebarSelectedBackgroundBrush" Color="#2A2E38" />
    <SolidColorBrush x:Key="SidebarHoverBackgroundBrush" Color="#20242C" />
    <SolidColorBrush x:Key="SidebarHeaderBrush" Color="#7C828E" />
    <SolidColorBrush x:Key="SearchHintBrush" Color="#7A8090" />

    <!-- Content -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#1B1E25" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#23272F" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#333842" />

    <!-- Accent: lifted slightly so it holds up against a dark field. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#5B8DEF" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#6D9BF2" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#4A7CDB" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6E8EC" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA1AE" />
    <SolidColorBrush x:Key="WarningBrush" Color="#E57368" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#2E333C" />
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#383E49" />

    <!-- Chips -->
    <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#2E333C" />
    <SolidColorBrush x:Key="ChipBorderBrush" Color="#3D434E" />
    <SolidColorBrush x:Key="ChipTextBrush" Color="#E6E8EC" />
    <SolidColorBrush x:Key="AllCharactersBorderBrush" Color="#E0A030" />

    <!-- Scrollbars -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#454B57" />

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2A2F38" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3D434E" />
    <SolidColorBrush x:Key="InputDisabledBackgroundBrush" Color="#22262D" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#2A2F38" />

</ResourceDictionary>
